# URL the browser uses to reach the client HTTP server
# Local dev: http://localhost:3001
# Production: https://your-client-server.example.com
VITE_CLIENT_URL=http://localhost:3001

# Base path for the frontend — must match the URL path it is served from.
# Local dev / Netlify / Render: /
# GitHub Pages project repo: /your-repo-name/
VITE_BASE_PATH=/
