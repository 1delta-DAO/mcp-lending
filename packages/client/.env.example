# AI provider to use: "anthropic" (default), "google", "groq", "mistral", or "deepseek"
AI_PROVIDER=anthropic

# Required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required when AI_PROVIDER=google
GOOGLE_API_KEY=AIza...

# Required when AI_PROVIDER=groq
# Get a free key at https://console.groq.com
GROQ_API_KEY=gsk_...

# Required when AI_PROVIDER=mistral
# Get a free key at https://console.mistral.ai
MISTRAL_API_KEY=...

# Required when AI_PROVIDER=deepseek
# Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# Optional — HTTP port the client server listens on (default: 3001)
PORT=3001
