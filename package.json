{
  "name": "mcp-lending-agent",
  "version": "0.1.0",
  "description": "MCP server and client for AI-powered lending platform interaction",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter @mcp-lending/backend build",
    "start:client": "pnpm --filter @mcp-lending/client start",
    "start:frontend": "pnpm --filter @mcp-lending/frontend dev",
    "deploy:backend": "railway up --service backend",
    "deploy:frontend": "pnpm --filter @mcp-lending/frontend deploy:railway",    
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "workspaces": [
    "packages/backend",
    "packages/client",
    "packages/frontend"
  ],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
